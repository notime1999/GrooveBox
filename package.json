{
  "name": "groovebox",
  "version": "1.0.0",
  "description": "A Discord bot that plays music from Spotify and YouTube.",
  "main": "src/bot.ts",
  "scripts": {
    "prestart": "npm run build",
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/bot.ts",
    "prod": "npm run build && npm run start",
    "start": "node dist/bot.js",
    "deploy": "ts-node src/commands/deploy-commands.ts"
  },
  "dependencies": {
    "@discordjs/opus": "^0.10.0",
    "@discordjs/voice": "^0.19.2",
    "discord.js": "^14.24.2",
    "dotenv": "^10.0.0",
    "libsodium-wrappers": "^0.8.2",
    "opusscript": "^0.0.8",
    "sodium-native": "^5.1.0",
    "spotify-web-api-node": "^5.0.0",
    "youtube-dl-exec": "^3.0.26",
    "yt-search": "^2.13.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "ffmpeg-static": "^4.4.1",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.1.6"
  },
  "keywords": [
    "discord",
    "music",
    "bot",
    "spotify",
    "youtube"
  ],
  "author": "Notime1999",
  "license": "MIT"
}
